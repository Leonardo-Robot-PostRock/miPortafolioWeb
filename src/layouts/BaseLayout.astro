---
import '@/styles/global.css';

interface Props {
  title?: string;
  titleEn?: string;
  description?: string;
  descriptionEn?: string;
  image?: string;
  /** Set to false on pages that should not be indexed (e.g. drafts) */
  noIndex?: boolean;
}

const {
  title = 'Leonardo Puebla — Desarrollador React, Angular & Node.js | Mendoza',
  titleEn = 'Leonardo Puebla — React, Angular & Node.js Developer | Mendoza',
  description = 'Portfolio de Leonardo Puebla, Desarrollador Frontend & Full-Stack en Mendoza, Argentina. +3 años creando aplicaciones web con React, Angular, Svelte, Node.js, TypeScript y PostgreSQL.',
  descriptionEn = 'Portfolio of Leonardo Puebla, Frontend & Full-Stack Developer based in Mendoza, Argentina. 3+ years building web apps with React, Angular, Svelte, Node.js, TypeScript and PostgreSQL.',
  image = '/og-image.webp',
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://leonardopuebla.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);

// ─── Nota hreflang ───────────────────────────────────────────────────
// El i18n actual es client-side (localStorage), no hay rutas /en/ reales.
// Cuando se implemente routing por idioma, agregar en el <head>:
//   <link rel="alternate" hreflang="es" href={canonicalURL} />
//   <link rel="alternate" hreflang="en" href={`${siteUrl}/en${Astro.url.pathname}`} />
//   <link rel="alternate" hreflang="x-default" href={canonicalURL} />

// JSON-LD: Person — datos estructurados de la persona
const jsonLdPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#person`,
  "name": "Leonardo Puebla",
  "url": siteUrl,
  "email": "contact@leonardopuebla.com",
  "jobTitle": "Frontend Developer · Full Stack",
  "description": "Desarrollador Frontend con perfil Full Stack y +3 años de experiencia construyendo y modernizando aplicaciones web y móviles. Basado en Luján de Cuyo, Mendoza, Argentina.",
  "image": `${siteUrl}/og-image.webp`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Luján de Cuyo",
    "addressRegion": "Mendoza",
    "addressCountry": "AR"
  },
  "sameAs": [
    "https://github.com/Leonardo-Robot-PostRock",
    "https://www.linkedin.com/in/leonardocode/",
    "https://x.com/LeoluxMrQwerty"
  ],
  "knowsAbout": [
    "React", "Angular", "Svelte", "SvelteKit", "TypeScript",
    "Node.js", "Python", "PostgreSQL", "Docker", "Astro"
  ]
};

// JSON-LD: WebSite — datos estructurados del sitio
const jsonLdWebSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": "Leonardo Puebla — Portfolio",
  "url": siteUrl,
  "author": { "@id": `${siteUrl}/#person` },
  "inLanguage": ["es", "en"],
  "description": description
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ─── Crawling & Indexing ──────────────────────────────────────── -->
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- ─── Primary Meta Tags ────────────────────────────────────────── -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Leonardo Puebla" />
    <meta name="keywords" content="Leonardo Puebla, Frontend Developer, Full Stack Developer, React, Angular, Svelte, Node.js, TypeScript, developer portfolio Mendoza Argentina" />

    <!-- ─── Open Graph ───────────────────────────────────────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={`${title} — og image`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:site_name" content="Leonardo Puebla — Portfolio" />

    <!-- ─── Twitter / X Card ─────────────────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@LeoluxMrQwerty" />
    <meta name="twitter:creator" content="@LeoluxMrQwerty" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={`${title} — og image`} />

    <!-- ─── Performance: resource hints ─────────────────────────────── -->
    <!-- Preconnect a Google Fonts para evitar bloqueo de render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Carga no bloqueante de fuentes con media="print" trick -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <!-- Fallback sin JS -->
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- ─── Favicons multi-formato ────────────────────────────────────── -->
    <!-- ICO para navegadores legacy (IE, etc.) -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <!-- SVG para navegadores modernos (soporta dark mode via CSS) -->
    <link rel="icon" href="/portfolio.svg" type="image/svg+xml" />
    <!-- Apple Touch Icon para iOS/Safari -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- Android/PWA icons -->
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />

    <!-- ─── Structured Data: Person (JSON-LD) ──────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdPerson)} />
    <!-- ─── Structured Data: WebSite (JSON-LD) ─────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />

    <!-- ─── Theme & Language init (prevent FOUC) ─────────────────────── -->
    <script is:inline>
      (function() {
        var mode = localStorage.getItem('color-mode') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', mode);
        var lang = localStorage.getItem('preferred-language') || 'es';
        document.documentElement.setAttribute('lang', lang);

        // Swap meta tags to the selected language on page load
        if (lang === 'en') {
          var titleEl = document.querySelector('meta[data-i18n-title-en]');
          var descEl = document.querySelector('meta[data-i18n-desc-en]');
          if (titleEl) {
            var enTitle = titleEl.getAttribute('data-i18n-title-en');
            document.title = enTitle;
            document.querySelectorAll('meta[property="og:title"], meta[name="twitter:title"], meta[name="title"]')
              .forEach(function(el) { el.setAttribute('content', enTitle); });
          }
          if (descEl) {
            var enDesc = descEl.getAttribute('data-i18n-desc-en');
            document.querySelectorAll('meta[property="og:description"], meta[name="twitter:description"], meta[name="description"]')
              .forEach(function(el) { el.setAttribute('content', enDesc); });
          }
        }
      })();
    </script>

    <!-- i18n data attributes for client-side language switching -->
    <meta data-i18n-title-en={titleEn} data-i18n-desc-en={descriptionEn} />
  </head>
  <body>
    <slot />
  </body>
</html>
