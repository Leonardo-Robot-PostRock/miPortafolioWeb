---
import { getImage } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Header } from '@/components/layout/Header';
import { ProjectDetail } from '@/components/sections/ProjectDetail';
import { Footer } from '@/components/layout/Footer';
import { ThemeSwitcher } from '@/components/ui/ThemeSwitcher';
import { portfolioData } from '@/data/portfolio';

export async function getStaticPaths() {
  return portfolioData.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Optimize hero image for detail page (max 1200px wide)
const optHero = project.image
  ? await getImage({ src: project.image.src, width: 1200, format: 'webp', quality: 85 })
  : undefined;

// Optimize gallery images (max 800px wide)
const optGallery = project.gallery
  ? await Promise.all(
      project.gallery.map(async (item) => {
        const targetW = 800;
        const targetH = Math.round(targetW * item.image.height / item.image.width);
        const opt = await getImage({ src: item.image.src, width: targetW, format: 'webp', quality: 85 });
        return { ...item, image: { src: opt.src, width: targetW, height: targetH } };
      })
    )
  : undefined;

const optimizedProject = {
  ...project,
  ...(optHero && {
    image: {
      src: optHero.src,
      width: 1200,
      height: Math.round(1200 * project.image!.height / project.image!.width),
    },
  }),
  ...(optGallery && { gallery: optGallery }),
};

const siteUrl = 'https://leonardopuebla.com';
const projectUrl = `${siteUrl}/project/${project.slug}`;
const imageUrl = project.image ? new URL(project.image.src, siteUrl).toString() : `${siteUrl}/og-image.webp`;

const jsonLdProject = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "@id": projectUrl,
  "name": project.title,
  "description": project.shortDescription.es,
  "url": projectUrl,
  "image": imageUrl,
  "author": {
    "@id": `${siteUrl}/#person`
  },
  "dateCreated": project.year ? `${project.year.split('–')[0]}-01-01` : undefined,
  "keywords": project.techStack.join(', '),
  ...(project.client ? { "producer": { "@type": "Organization", "name": project.client } } : {}),
};
---

<BaseLayout
  title={`${project.title} — Leonardo Puebla`}
  titleEn={`${project.title} — Leonardo Puebla`}
  description={project.shortDescription.es}
  descriptionEn={project.shortDescription.en}
  image={project.image?.src}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdProject)} slot="head" />
  <Header client:load />

  <main>
    <ProjectDetail project={optimizedProject} client:load />
  </main>

  <Footer socialLinks={portfolioData.personal.socialLinks} client:load />
  <ThemeSwitcher client:load />
</BaseLayout>
