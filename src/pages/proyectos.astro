---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Header } from '@/components/layout/Header';
import { Projects } from '@/components/sections/Projects';
import { Footer } from '@/components/layout/Footer';
import { ThemeSwitcher } from '@/components/ui/ThemeSwitcher';
import { portfolioData } from '@/data/portfolio';
---

<BaseLayout
  title="Proyectos — Leonardo Puebla"
  titleEn="Projects — Leonardo Puebla"
  description="Todos los proyectos de desarrollo web de Leonardo Puebla. Aplicaciones modernas, escalables y bien documentadas."
  descriptionEn="All web development projects by Leonardo Puebla. Modern, scalable, and well-documented applications."
>
  <Header client:load />

  <main class="pt-20">
    <Projects projects={portfolioData.projects} client:load />
  </main>

  <Footer socialLinks={portfolioData.personal.socialLinks} client:load />
  <ThemeSwitcher client:load />
</BaseLayout>
